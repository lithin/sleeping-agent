# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sleepagent

# Backend (Prisma connection string)
DATABASE_URL=postgresql://postgres:postgres@db:5432/sleepagent?schema=public

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# API Security
# Generate a strong random key for production: openssl rand -hex 32
API_SECRET_KEY=dev-secret-key-change-in-production
